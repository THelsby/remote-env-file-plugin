<?jelly escape-by-default='true'?>
<j:jelly xmlns:j="jelly:core" xmlns:f="/lib/form">
  <f:entry title="Warning">
    <div>
      Remote values become ordinary environment variables. If a build step echoes them, Jenkins does not mask or protect those values automatically.
    </div>
  </f:entry>
  <f:entry title="Sources" field="sources">
    <f:repeatableProperty field="sources" add="Add source" minimum="1"/>
  </f:entry>
</j:jelly>
